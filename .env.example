# Bunny Storage deployment
# Copy this file to .env in a real project repo and fill in the values.
# Do not commit .env.

BUNNY_STORAGE_ENDPOINT=storage.bunnycdn.com
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_ACCESS_KEY=

# Optional CDN purge settings
BUNNY_API_KEY=
BUNNY_PULL_ZONE_ID=
BUNNY_PURGE_MODE=full
BUNNY_PUBLIC_BASE_URL=
BUNNY_PURGE_URLS=
BUNNY_CLEAN_DEPLOY=false

# Optional IndexNow settings
# Generate a key for the real project and keep it stable across deploys.
INDEXNOW_KEY=
INDEXNOW_ENDPOINT=https://api.indexnow.org/indexnow
INDEXNOW_MODE=changed-urls
