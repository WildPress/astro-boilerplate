{
  "name": "astro-boilerplate",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "NODE_ENV=development astro dev --host 0.0.0.0 --mode development",
    "lint": "eslint . --max-warnings=0",
    "verify:standards": "node scripts/verify-standards.mjs",
    "validate": "npm run verify:standards && npm run lint && npm run build",
    "build": "npm run verify:standards && astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/preact": "^5.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@floating-ui/dom": "^1.7.4",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/newsreader": "^5.2.8",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "4.2.2",
    "astro": "^6.4.2",
    "lucide": "^1.8.0",
    "pagefind": "^1.4.0",
    "preact": "^10.28.0",
    "swiper": "^12.1.3",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "overrides": {
    "vite": "7.3.3"
  }
}
