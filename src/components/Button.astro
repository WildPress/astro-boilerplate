---
import Icon from './Icon.astro';
import type { IconName } from '../lib/icon-names';

interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'tertiary';
  tone?: 'default' | 'light';
  size?: 'default' | 'large';
  icon?: boolean | IconName;
  fullWidth?: boolean | 'true' | 'false';
  target?: string;
  rel?: string;
  class?: string;
}

const {
  href,
  type = 'button',
  variant = 'primary',
  tone = 'default',
  size = 'default',
  icon = false,
  fullWidth = false,
  target,
  rel,
  class: className = '',
} = Astro.props;

const baseClass = 'inline-flex cursor-pointer items-center justify-center whitespace-nowrap rounded border text-xs font-bold uppercase tracking-normal transition-[border-color,background-color,color,box-shadow] duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-950';
const gapClass = variant === 'tertiary' ? 'gap-1' : 'gap-2';
const sizeClass = size === 'large'
  ? variant === 'tertiary'
    ? 'h-14'
    : 'h-14 min-w-[220px] px-8'
  : variant === 'tertiary'
    ? 'h-11'
    : 'h-11 min-w-[160px] px-6';
const variantClass =
  tone === 'light' && variant === 'primary'
    ? 'border-white bg-white text-neutral-950 hover:bg-neutral-100'
    : tone === 'light' && variant === 'secondary'
      ? 'border-white/60 bg-transparent text-white hover:border-white hover:bg-white hover:text-neutral-950'
      : variant === 'primary'
        ? 'border-neutral-950 bg-neutral-950 text-white shadow-sm hover:border-neutral-700 hover:bg-neutral-700'
        : variant === 'secondary'
          ? 'border-neutral-300 bg-white text-neutral-950 hover:border-neutral-950'
          : 'min-w-0 border-0 bg-transparent px-0 text-neutral-950 hover:text-neutral-600';
const widthClass = fullWidth === true || fullWidth === 'true' ? 'flex w-full' : '';
const iconSize = variant === 'tertiary' ? 'compact' : 'default';
const iconName = icon === true ? 'move-right' : icon || undefined;
---

{href ? (
  <a href={href} target={target} rel={rel} class:list={[baseClass, gapClass, sizeClass, variantClass, widthClass, className]}>
    <slot />
    {iconName && <Icon name={iconName} size={iconSize} />}
  </a>
) : (
  <button type={type} class:list={[baseClass, gapClass, sizeClass, variantClass, widthClass, className]}>
    <slot />
    {iconName && <Icon name={iconName} size={iconSize} />}
  </button>
)}
