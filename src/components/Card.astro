---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  border?: boolean | 'true' | 'false';
  rounded?: boolean | 'true' | 'false';
  padded?: boolean | 'true' | 'false';
  class?: string;
}

const {
  as: Tag = 'div',
  border = true,
  rounded = false,
  padded = false,
  class: className = '',
  ...attributes
} = Astro.props;

const borderClass = border === true || border === 'true' ? '' : 'border-0';
const roundedClass = rounded === true || rounded === 'true' ? 'overflow-hidden rounded-card' : '';
const paddedClass = padded === true || padded === 'true' ? 'p-5 sm:p-6' : '';
---

<Tag {...attributes} class:list={['card', borderClass, roundedClass, paddedClass, className]}>
  <slot />
</Tag>
