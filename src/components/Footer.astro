---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-[var(--line)] bg-white">
  <div class="shell flex flex-col gap-4 py-8 sm:flex-row sm:items-center sm:justify-between">
    <a href="/" aria-label="Go to homepage" class="font-serif text-2xl font-medium text-[var(--ink)]">Astro Boilerplate</a>
    <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-[var(--muted)]">
      <a href="#components" class="hover:text-[var(--ink)]">Components</a>
      <a href="#standards" class="hover:text-[var(--ink)]">Standards</a>
      <a href="#verification" class="hover:text-[var(--ink)]">Verification</a>
      <span>&copy; {currentYear}</span>
    </div>
  </div>
</footer>
