---
import {
  ArrowRight,
  BadgeCheck,
  ChevronDown,
  ChevronRight,
  ExternalLink,
  Mail,
  Menu,
  MoveRight,
  Search,
  ShieldCheck,
  Star,
  X,
} from 'lucide';
import type { IconName } from '../lib/icon-names';

interface Props {
  name: IconName;
  size?: 'compact' | 'default' | 'md';
  filled?: boolean;
  class?: string;
}

const {
  name,
  size = 'default',
  filled = false,
  class: className = '',
} = Astro.props;

const icons: Record<IconName, unknown[]> = {
  'arrow-right': ArrowRight,
  'badge-check': BadgeCheck,
  'chevron-down': ChevronDown,
  'chevron-right': ChevronRight,
  'external-link': ExternalLink,
  mail: Mail,
  menu: Menu,
  'move-right': MoveRight,
  search: Search,
  'shield-check': ShieldCheck,
  star: Star,
  x: X,
};

const iconNode = icons[name] as [string, Record<string, string>][];
const sizeClass = size === 'compact' ? 'h-3 w-3' : size === 'md' ? 'h-5 w-5' : 'h-4 w-4';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill={filled ? 'currentColor' : 'none'}
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={[sizeClass, 'shrink-0', className]}
  aria-hidden="true"
>
  {iconNode.map(([tag, attrs]) => {
    if (tag === 'path') return <path {...attrs} />;
    if (tag === 'circle') return <circle {...attrs} />;
    if (tag === 'line') return <line {...attrs} />;
    if (tag === 'polyline') return <polyline {...attrs} />;
    if (tag === 'polygon') return <polygon {...attrs} />;
    if (tag === 'rect') return <rect {...attrs} />;
    return null;
  })}
</svg>
