---
import Button from './Button.astro';

const navItems = [
  { href: '#components', label: 'Components' },
  { href: '#standards', label: 'Standards' },
  { href: '#verification', label: 'Verification' },
];
---

<header class="sticky top-0 z-50 border-b border-neutral-200 bg-white/95 backdrop-blur-xl">
  <div class="shell flex min-h-20 items-center justify-between gap-5 py-4">
    <a href="/" aria-label="Go to homepage" class="flex flex-col leading-none text-neutral-950">
      <span class="font-serif text-3xl font-medium">Astro Boilerplate</span>
      <span class="mt-1 text-[0.68rem] font-bold uppercase text-neutral-600">Reusable Astro build system</span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      <nav class="flex items-center gap-7" aria-label="Primary">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="border-b border-transparent pb-1 text-sm font-bold text-neutral-700 transition hover:border-neutral-950 hover:text-neutral-950"
          >
            {item.label}
          </a>
        ))}
      </nav>
      <Button href="#verification" icon={true}>Verify</Button>
    </div>
  </div>
</header>
