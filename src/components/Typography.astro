---
interface Props {
  as?: keyof HTMLElementTagNameMap;
  variant?: 'display' | 'heading' | 'title' | 'body' | 'meta' | 'label';
  class?: string;
}

const {
  as: Tag = 'p',
  variant = 'body',
  class: className = '',
} = Astro.props;

const classes = {
  display: 'font-serif text-5xl leading-[1.02] font-medium tracking-normal text-neutral-950 sm:text-7xl sm:leading-none',
  heading: 'font-serif text-3xl leading-tight font-medium tracking-normal text-neutral-950 sm:text-5xl',
  title: 'font-serif text-2xl leading-snug font-medium tracking-normal text-neutral-950 sm:text-3xl',
  body: 'text-base leading-7 text-neutral-600',
  meta: 'text-sm leading-6 text-neutral-500',
  label: 'text-xs font-bold uppercase leading-4 tracking-normal text-neutral-700',
};
---

<Tag class:list={[classes[variant], className]}>
  <slot />
</Tag>
