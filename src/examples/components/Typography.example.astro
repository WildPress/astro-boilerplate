---
import Typography from '../../components/Typography.astro';
---

<div class="grid gap-5">
  <Typography as="h1" variant="display">Display typography</Typography>
  <Typography as="h2" variant="heading">Heading typography</Typography>
  <Typography as="h3" variant="title">Title typography</Typography>
  <Typography variant="body">Body typography is intended for readable supporting copy and paragraph text.</Typography>
  <Typography variant="meta">Meta typography is for secondary facts, dates, captions, and helper copy.</Typography>
  <Typography variant="label">Label Typography</Typography>
</div>
