---
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Section from '../components/Section.astro';
import Typography from '../components/Typography.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const standards = [
  'Tailwind utilities for page and component styling',
  'No component-scoped CSS or inline style attributes',
  'Pinned dependency allowlist with Preact islands by default',
  'Strict Astro, TypeScript, accessibility, and standards verification before build',
];
---

<BaseLayout title="Astro Boilerplate" description="A strict Astro starter for reusable, standards-led site builds.">
  <Section background="dark" top="xl" bottom="xl">
    <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
      <div class="max-w-3xl">
        <p class="eyebrow">Astro starter</p>
        <Typography as="h1" variant="display" class="text-white">A strict base for new Astro builds.</Typography>
        <Typography class="mt-6 max-w-2xl text-white/75">
          Shared components, fixed build rules, and automated checks keep new projects consistent without carrying over project-specific content.
        </Typography>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="#components" tone="light" icon={true}>View Components</Button>
          <Button href="#verification" tone="light" variant="secondary">Verification</Button>
        </div>
      </div>
      <Card rounded={true} padded={true} class="border-white/20 bg-white/10 text-white shadow-none">
        <Typography variant="label" class="text-white/70">Baseline</Typography>
        <ul class="mt-5 grid gap-4 text-sm text-white/78">
          {standards.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-white/70"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </Card>
    </div>
  </Section>

  <Section id="components" top="xl" bottom="lg">
    <div class="grid gap-8 md:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Components</p>
        <Typography as="h2" variant="heading">Reusable primitives</Typography>
        <Typography class="mt-4">
          Start new builds with layout, section, typography, cards, buttons, icons, header, and footer already aligned.
        </Typography>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {['Button', 'Card', 'Section', 'Typography', 'Icon', 'BaseLayout'].map((name) => (
          <Card rounded={true} padded={true}>
            <Typography as="h3" variant="title">{name}</Typography>
            <Typography variant="meta" class="mt-2">Token-led, Tailwind-first, and ready to adapt per project.</Typography>
          </Card>
        ))}
      </div>
    </div>
  </Section>

  <Section id="standards" top="lg" bottom="lg" background="white" border={true}>
    <div class="max-w-3xl">
      <p class="eyebrow">Standards</p>
      <Typography as="h2" variant="heading">Rules live in code and docs.</Typography>
      <Typography class="mt-4">
        The boilerplate documents the component contract in README and AGENTS, then enforces the high-risk drift points with scripts.
      </Typography>
    </div>
  </Section>

  <Section id="verification" top="lg" bottom="xl">
    <div class="grid gap-6 lg:grid-cols-3">
      {['npm run verify:standards', 'npm run lint', 'npm run build'].map((command) => (
        <Card rounded={true} padded={true}>
          <Typography variant="label">Required</Typography>
          <code class="mt-3 block rounded bg-neutral-950 px-4 py-3 text-sm text-white">{command}</code>
        </Card>
      ))}
    </div>
  </Section>
</BaseLayout>
